    "nanoid": "^5.1.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^20.4.1",
    "viem": "^2.47.6",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
